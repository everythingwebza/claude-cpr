# ─── Project list ──────────────────────────────────────────────────────

def render_project_list(sorted_projects, proj_sessions, proj_latest, cursor, scroll_offset, visible_rows):
    lines = []
    lines.append(f"  {BOLD}{WHITE}All Claude Code Projects{RESET}")
    lines.append(f"  {DIM}{'─' * 70}{RESET}")
    lines.append("")
    lines.append(f"  {DIM}{'':>3}  {'Project':<40} {'Sessions':>8}  {'Last Active':>12}{RESET}")
    lines.append(f"  {DIM}{'─' * 70}{RESET}")

    total_count = len(sorted_projects)
    for i in range(scroll_offset, min(scroll_offset + visible_rows, total_count)):
        proj = sorted_projects[i]
        name = short_project_name(proj)
        count = len(proj_sessions[proj])
        ago = format_time_ago(proj_latest[proj])
        active = is_project_active(proj)
        active_marker = f"{RED}*{RESET}" if active else " "
        num = i + 1
        if i == cursor:
            lines.append(f"  {REVERSE}{BOLD} {num:>3} {active_marker} {name:<40}  {count:>8}  {ago:>12} {RESET}")
        else:
            lines.append(f"  {DIM}{num:>3}{RESET} {active_marker} {CYAN}{name:<40}{RESET} {WHITE}{count:>8}{RESET}  {DIM}{ago:>12}{RESET}")

    total = sum(len(v) for v in proj_sessions.values())
    lines.append("")
    if total_count > visible_rows:
        pos = scroll_offset + 1
        end = min(scroll_offset + visible_rows, total_count)
        lines.append(f"  {DIM}Showing {pos}-{end} of {total_count} projects ({total} sessions){RESET}")
    else:
        lines.append(f"  {DIM}{total_count} projects, {total} total sessions{RESET}")
    lines.append("")
    lines.append(f"  {hint('↑↓', 'navigate')}  {hint('Enter', 'select')}  {hint('/', 'search')}  {hint('Esc', 'back')}  {hint('q', 'quit')}  {hint('?', 'help')}")
    return lines


def _build_project_data():
    sessions = build_session_list()
    if not sessions:
        print(f"{YELLOW}No Claude projects found.{RESET}")
        return None
    proj_sessions = OrderedDict()
    proj_latest = {}
    for s in sessions:
        p = s["project"]
        if p not in proj_sessions:
            proj_sessions[p] = []
            proj_latest[p] = s["modified"]
        proj_sessions[p].append(s)
    sorted_projects = sorted(proj_sessions.keys(), key=lambda p: proj_latest[p], reverse=True)
    return sorted_projects, proj_sessions, proj_latest


def cmd_list():
    data = _build_project_data()
    if not data:
        return "quit"
    if is_tty():
        return _cmd_list_tui(*data)
    else:
        return _cmd_list_fallback(*data)


def _cmd_list_fallback(sorted_projects, proj_sessions, proj_latest):
    while True:
        print(f"\n  {BOLD}{WHITE}All Claude Code Projects{RESET}")
        print(f"  {DIM}{'─' * 70}{RESET}")
