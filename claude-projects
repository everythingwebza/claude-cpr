    return lines


def _show_sessions_tui(project_path, sessions):
    """Arrow-key navigable session list — fully scrollable. Returns 'back' or 'quit'."""
    total_items = len(sessions) + 1
    cursor = 0
    scroll_offset = 0
    overhead = 7
    prev_line_count = 0

    sys.stdout.write(HIDE_CURSOR)
    sys.stdout.flush()

    try:
        while True:
            term_height = get_terminal_height()
            visible_rows = max(3, (term_height - overhead) // 3)
            cursor = max(0, min(cursor, total_items - 1))

            if cursor < scroll_offset:
                scroll_offset = cursor
            elif cursor >= scroll_offset + visible_rows:
                scroll_offset = cursor - visible_rows + 1

            lines = render_session_list(project_path, sessions, cursor, scroll_offset, visible_rows)

            clear_lines(prev_line_count)
            sys.stdout.write("\n".join(lines) + "\n")
            sys.stdout.flush()
            prev_line_count = len(lines)

            key = read_key()

            if key in ("ctrl-c", "q"):
                return "quit"
            if key == "esc":
                return check_esc()
            elif key in ("up", "k"):
                if cursor > 0:
                    cursor -= 1
            elif key in ("down", "j"):
                if cursor < total_items - 1:
                    cursor += 1

            elif key == "?":
                clear_lines(prev_line_count)
                prev_line_count = 0
                show_help_overlay("sessions")

            elif key in ("p", "right"):
                if cursor < len(sessions):
                    clear_lines(prev_line_count)
                    prev_line_count = 0
                    sys.stdout.write(SHOW_CURSOR)
                    sys.stdout.flush()
                    action = show_preview(sessions[cursor])
                    if action == "quit":
                        return "quit"
                    sys.stdout.write(HIDE_CURSOR)
                    sys.stdout.flush()

            elif key == "enter":
                clear_lines(prev_line_count)
                prev_line_count = 0
                sys.stdout.write(SHOW_CURSOR)
                sys.stdout.flush()

                if cursor < len(sessions):
                    if resume_session(sessions[cursor]):
                        sys.stdout.write(HIDE_CURSOR)
                        sys.stdout.flush()
                        continue
                    return "quit"  # unreachable after exec
                else:
                    if new_session(project_path):
                        sys.stdout.write(HIDE_CURSOR)
                        sys.stdout.flush()
                        continue
                    return "quit"  # unreachable after exec

    finally:
        clear_lines(prev_line_count)
        sys.stdout.write(SHOW_CURSOR)
        sys.stdout.flush()


def _show_sessions_fallback(project_path, sessions):
    """Fallback session list using number input. Returns 'back' or 'quit'."""
    name = short_project_name(project_path)
    proj_active = is_project_active(project_path)

    while True:
        print()
        active_label = f"  {RED}{BOLD}ACTIVE{RESET}" if proj_active else ""
        print(f"  {BOLD}{CYAN}{name}{RESET}  {DIM}{project_path}{RESET}{active_label}")
        print(f"  {DIM}{'─' * 70}{RESET}")
        print()
        for i, s in enumerate(sessions, 1):
            print_session_row(i, s, active=(proj_active and i == 1))
            print()
        print(f"  {DIM}{'─' * 70}{RESET}")
        print(f"    {BOLD}{GREEN} n{RESET}  {WHITE}New session{RESET}")
        print()
        choice = prompt_input(
            f"  {BOLD}Enter session number, {DIM}n{RESET}{BOLD}ew session, "
            f"{DIM}b{RESET}{BOLD}ack, or {DIM}q{RESET}{BOLD}uit:{RESET} "
        )
        if choice.lower() == "q":
            return "quit"
        if choice.lower() in ("b", ""):
            return "back"
        if choice.lower() == "n":
            if new_session(project_path):
                continue
            return "quit"
        try:
            idx = int(choice) - 1
            if 0 <= idx < len(sessions):
                if resume_session(sessions[idx]):
                    continue
                return "quit"
            else:
                print(f"  {YELLOW}Invalid selection.{RESET}")
        except ValueError:
            print(f"  {YELLOW}Invalid input.{RESET}")


# ─── Quick picker ──────────────────────────────────────────────────────

def _build_pick_rows(max_sessions=10, top_projects=5, per_project=2):
    sessions = build_session_list()
    if not sessions:
        return None, None

    proj_sessions = OrderedDict()
    for s in sessions:
        p = s["project"]
        if p not in proj_sessions:
            proj_sessions[p] = []
        proj_sessions[p].append(s)

    top_projs = list(proj_sessions.keys())[:top_projects]
    rows = []
    selectable = []
    session_count = 0

    for proj in top_projs:
        if session_count >= max_sessions:
            break
        proj_active = is_project_active(proj)
        name = short_project_name(proj)
        rows.append({"type": "header", "name": name, "path": proj, "active": proj_active})

        first_in_proj = True
        for s in proj_sessions[proj][:per_project]:
            if session_count >= max_sessions:
                break
            active_label = proj_active and first_in_proj
            first_in_proj = False
            idx = len(rows)
            rows.append({"type": "session", "session": s, "active_label": active_label})
            selectable.append(idx)
            session_count += 1

    return rows, selectable


def render_pick_rows(rows, selectable, cursor, scroll_offset, visible_rows):
    lines = []
    lines.append(f"  {BOLD}{WHITE}Recent Claude Sessions{RESET}")
    lines.append(f"  {DIM}{'─' * 70}{RESET}")
    lines.append("")

    if not selectable:
        lines.append(f"  {YELLOW}No sessions found.{RESET}")
        return lines

    vis_start = scroll_offset
    vis_end = min(scroll_offset + visible_rows, len(selectable))

    first_row = selectable[vis_start]
    last_row = selectable[vis_end - 1]

    header_start = first_row
    for r in range(first_row - 1, -1, -1):
        if rows[r]["type"] == "header":
            header_start = r
            break

    for ri in range(header_start, last_row + 1):
        row = rows[ri]
        if row["type"] == "header":
            active_label = f"  {RED}{BOLD}ACTIVE{RESET}" if row["active"] else ""
            lines.append(f"  {BOLD}{CYAN}{row['name']}{RESET}  {DIM}{row['path']}{RESET}{active_label}")
        elif row["type"] == "session":
            s = row["session"]
            title = truncate(s["title"])
            ago = format_time_ago(s["modified"])
            date = format_date(s["modified"])
            msgs = s["msgCount"]
            branch = s["branch"]
            active_str = f" {RED}{BOLD}ACTIVE{RESET}" if row["active_label"] else ""
            branch_str = f" {MAGENTA}{branch}{RESET}" if branch else ""
            msg_str = f"{msgs} msgs" if msgs else ""
            is_selected = ri == selectable[cursor]

            if is_selected:
                lines.append(f"  {REVERSE}{BOLD}  ▸ {title:<68}{RESET}{active_str}")
                lines.append(f"  {REVERSE}      {date} ({ago}){' · ' + msg_str if msg_str else ''}{' ' + branch if branch else '':>20}{RESET}")
            else:
                lines.append(f"      {WHITE}{title}{RESET}{active_str}")
                lines.append(f"      {DIM}{date} ({ago}){' · ' + msg_str if msg_str else ''}{branch_str}{RESET}")
            lines.append("")

    lines.append(f"  {DIM}{'─' * 70}{RESET}")
    total = len(selectable)
    if total > visible_rows:
        lines.append(f"  {DIM}Showing {vis_start + 1}-{vis_end} of {total} sessions{RESET}")
    lines.append(f"  {hint('↑↓', 'navigate')}  {hint('Enter', 'resume')}  {hint('p/→', 'preview')}  {hint('/', 'search')}  {hint('l', 'all projects')}  {hint('?', 'help')}")
    return lines


def cmd_pick(max_sessions=10, top_projects=5, per_project=2):
    rows, selectable = _build_pick_rows(max_sessions, top_projects, per_project)
    if not rows:
        print(f"{YELLOW}No Claude sessions found.{RESET}")
