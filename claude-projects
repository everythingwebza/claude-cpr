    if is_tty():
        return _show_sessions_tui(project_path, sessions)
    else:
        return _show_sessions_fallback(project_path, sessions)


def render_session_list(project_path, sessions, cursor, scroll_offset, visible_rows):
    """Render scrollable session list for a project."""
    name = short_project_name(project_path)
    proj_active = is_project_active(project_path)
