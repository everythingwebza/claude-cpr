            elif key in ("up", "k"):
                if cursor > 0:
                    cursor -= 1

            elif key in ("down", "j"):
                if cursor < total - 1:
                    cursor += 1

            elif key == "enter":
                clear_lines(prev_line_count)
                prev_line_count = 0
                sys.stdout.write(SHOW_CURSOR)
                sys.stdout.flush()
                row = rows[selectable[cursor]]
                if resume_session(row["session"]):
                    sys.stdout.write(HIDE_CURSOR)
                    sys.stdout.flush()
                    continue
                return  # unreachable after exec

    finally:
        clear_lines(prev_line_count)
        sys.stdout.write(SHOW_CURSOR)
        sys.stdout.flush()


def _cmd_pick_fallback(rows, selectable):
    """Non-TTY fallback: numbered list with text input."""
    print()
    print(f"  {BOLD}{WHITE}Recent Claude Sessions{RESET}")
    print(f"  {DIM}{'─' * 70}{RESET}")
    print()

    for ri, row in enumerate(rows):
        if row["type"] == "header":
            active_label = f"  {RED}{BOLD}ACTIVE{RESET}" if row["active"] else ""
            print(f"  {BOLD}{CYAN}{row['name']}{RESET}  {DIM}{row['path']}{RESET}{active_label}")
        elif row["type"] == "session":
            num = selectable.index(ri) + 1
            print_session_row(num, row["session"], active=row["active_label"])
            print()

    print(f"  {DIM}{'─' * 70}{RESET}")

    choice = prompt_input(
        f"  {BOLD}Enter number to resume, {DIM}l{RESET}{BOLD}ist all, or {DIM}q{RESET}{BOLD}uit:{RESET} "
    )

    if choice.lower() in ("q", ""):
        return
    if choice.lower() == "l":
        cmd_list()
        return

    try:
        idx = int(choice) - 1
        if 0 <= idx < len(selectable):
            resume_session(rows[selectable[idx]]["session"])
        else:
            print(f"  {YELLOW}Invalid selection.{RESET}")
    except ValueError:
        print(f"  {YELLOW}Invalid input.{RESET}")


