            elif key in ("up", "k"):
                if cursor > 0:
                    cursor -= 1
            elif key in ("down", "j"):
                if cursor < total_count - 1:
                    cursor += 1

            elif key == "?":
                clear_lines(prev_line_count)
                prev_line_count = 0
                show_help_overlay("projects")

            elif key == "/":
                clear_lines(prev_line_count)
                prev_line_count = 0
