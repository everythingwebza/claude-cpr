        if choice.lower() == "q":
            return "quit"
        if choice.lower() in ("b", ""):
            return "back"
        try:
            idx = int(choice) - 1
            if not (0 <= idx < len(sorted_projects)):
                print(f"  {YELLOW}Invalid selection.{RESET}")
