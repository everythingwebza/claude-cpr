            active_str = f" {RED}{BOLD}*{RESET}" if active else "  "
            print(f"  {DIM}{i:>3}{RESET}{active_str}{CYAN}{name:<40}{RESET} {WHITE}{count:>8}{RESET}  {DIM}{ago:>12}{RESET}")
        total = sum(len(v) for v in proj_sessions.values())
