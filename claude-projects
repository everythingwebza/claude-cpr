def main():
    args = sys.argv[1:]

    if "help" in args or "-h" in args or "--help" in args:
        cmd_help()
    elif "search" in args:
        sessions = build_session_list()
        if sessions:
            cmd_search(sessions)
        else:
            print(f"{YELLOW}No Claude sessions found.{RESET}")
    elif "list" in args:
        cmd_list()
    else:
        max_sessions = 10
        top_projects = 5
        per_project = 2
        if "-n" in args:
            try:
                max_sessions = int(args[args.index("-n") + 1])
            except (IndexError, ValueError):
                pass
        if "-p" in args:
            try:
                top_projects = int(args[args.index("-p") + 1])
            except (IndexError, ValueError):
                pass
        cmd_pick(max_sessions=max_sessions, top_projects=top_projects, per_project=per_project)


if __name__ == "__main__":
    main()
