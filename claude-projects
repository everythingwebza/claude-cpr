            if cursor == i:
                lines.append(f"  {REVERSE}{BOLD}  ▸ {'New session':<68}{RESET}")
            else:
                lines.append(f"      {GREEN}{BOLD}New session{RESET}")
            lines.append("")

    lines.append(f"  {DIM}{'─' * 70}{RESET}")
    if total_items > visible_rows:
